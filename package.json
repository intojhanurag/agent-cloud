{
  "name": "@intojhanurag/agent-cloud",
  "version": "1.0.0",
  "description": "AI-Powered Cloud Deployment CLI using Mastra",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "cloud-agent": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "mastra dev",
    "build": "tsc && mastra build",
    "start": "node dist/cli/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "cli": "tsx src/cli/index.ts",
    "cli:build": "node dist/cli/index.js",
    "docs:dev": "cd docs && npm run dev",
    "docs:build": "cd docs && npm run build",
    "prepublishOnly": "npm run type-check && npm run test:run && npm run build"
  },
  "keywords": [
    "ai",
    "cloud",
    "deployment",
    "mastra",
    "cli",
    "aws",
    "gcp",
    "azure",
    "devops"
  ],
  "author": "intojhanurag",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/intojhanurag/agent-cloud.git"
  },
  "homepage": "https://github.com/intojhanurag/agent-cloud#readme",
  "bugs": {
    "url": "https://github.com/intojhanurag/agent-cloud/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mastra/core": "^1.0.1",
    "@mastra/libsql": "^1.0.0",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "dotenv": "^17.2.4",
    "figlet": "^1.7.0",
    "gradient-string": "^2.0.2",
    "inquirer": "^9.2.15",
    "ora": "^8.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/figlet": "^1.5.8",
    "@types/gradient-string": "^1.1.6",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.16",
    "@vitest/coverage-v8": "^1.2.2",
    "mastra": "^1.0.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
